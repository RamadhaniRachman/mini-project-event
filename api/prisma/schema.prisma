generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model coupons {
  id                  Int            @id @default(autoincrement())
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  discount_percentage Int
  is_used             Boolean        @default(false)
  expired_at          DateTime       @db.Timestamptz(6)
  user_id             Int
  users               users          @relation(fields: [user_id], references: [id])
  transactions        transactions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model events {
  id           Int            @id @default(autoincrement())
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  title        String         @db.VarChar
  description  String?
  location     String         @db.VarChar
  category     String?        @db.VarChar
  event_date   DateTime       @db.Timestamptz(6)
  event_time   DateTime       @db.Timetz(6)
  is_free      Boolean        @default(false)
  organizer_id Int
  image_url    String?
  users        users          @relation(fields: [organizer_id], references: [id])
  promotions   promotions[]
  reviews      reviews[]
  tickets      tickets[]
  transactions transactions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model points {
  id                  Int      @id @default(autoincrement())
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  amount_earned       Int
  remaining_balance   Int
  expired_at          DateTime @db.Timestamptz(6)
  user_id             Int
  earned_from_user_id Int?
  earned_from         users?   @relation("EarnedPoints", fields: [earned_from_user_id], references: [id])
  users               users    @relation("UserPoints", fields: [user_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model promotions {
  id             Int            @id @default(autoincrement())
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  promo_code     String         @db.VarChar
  discount_value Int
  discount_type  String         @db.VarChar
  valid_from     DateTime       @db.Timestamptz(6)
  valid_until    DateTime       @db.Timestamptz(6)
  quota          Int
  event_id       Int
  event          events         @relation(fields: [event_id], references: [id])
  transactions   transactions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id          Int      @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  rating      Int
  feedback    String?
  suggestions String?
  event_id    Int
  customer_id Int
  user        users    @relation(fields: [customer_id], references: [id])
  event       events   @relation(fields: [event_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transactions {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // 👇 3 KOLOM BARU UNTUK FITUR PEMBAYARAN 👇
  updated_at    DateTime  @updatedAt @db.Timestamptz(6)
  payment_proof String?
  expires_at    DateTime? @db.Timestamptz(6)

  quantity       Int
  original_price Int
  point_redeemed Int         @default(0)
  final_price    Int
  status         String      @default("pending") @db.VarChar
  customer_id    Int
  event_id       Int
  ticket_type_id Int
  coupon_id      Int?
  promo_id       Int?
  coupon         coupons?    @relation(fields: [coupon_id], references: [id])
  user           users       @relation(fields: [customer_id], references: [id])
  event          events      @relation(fields: [event_id], references: [id])
  promo          promotions? @relation(fields: [promo_id], references: [id])
  ticket_type    tickets     @relation(fields: [ticket_type_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            Int    @id(map: "user_pkey") @default(autoincrement())
  name          String @db.VarChar
  email         String @unique(map: "user_email_key") @db.VarChar
  password      String @db.VarChar
  role          String @db.VarChar
  referral_code String @unique(map: "user_referral_code_key") @db.VarChar

  phone      String? @db.VarChar
  bio        String?
  avatar_url String?

  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  referred_by_id Int?
  coupons        coupons[]
  events         events[]
  earned_points  points[]       @relation("EarnedPoints")
  points         points[]       @relation("UserPoints")
  reviews        reviews[]
  transactions   transactions[]
  referred_by    users?         @relation("UserReferral", fields: [referred_by_id], references: [id])
  referrals      users[]        @relation("UserReferral")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tickets {
  id              Int            @id @default(autoincrement())
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  name            String         @db.VarChar
  price           Int
  available_seats Int
  event_id        Int
  event           events         @relation(fields: [event_id], references: [id])
  transactions    transactions[]
}
